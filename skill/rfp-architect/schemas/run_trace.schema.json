{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Skill runtime / eval trace record",
  "type": "object",
  "required": ["eval_id", "mode", "result"],
  "properties": {
    "eval_id": { "type": ["integer", "string"] },
    "mode": { "enum": ["write", "review", "consult"] },
    "result": { "enum": ["pass", "fail", "partial"] },
    "lint_blockers": { "type": "integer", "minimum": 0 },
    "rule_violations": { "type": "integer", "minimum": 0 },
    "notes": { "type": "string" }
  }
}
